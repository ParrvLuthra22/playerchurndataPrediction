# --- Python cache and bytecode ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environments ---
.venv/
venv/
env/

# --- Jupyter and notebook artifacts ---
.ipynb_checkpoints/
*.nbconvert.ipynb

